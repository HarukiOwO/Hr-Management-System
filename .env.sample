# ==========================================
# HR Management System (HRMS) - Sample Environment Variables
# Copy this file to .env and replace placeholders with actual values
# ==========================================

# --- Database & Docker Compose Configuration ---
MYSQL_DATABASE=hrms_db
DB_PASSWORD=change_me_to_a_secure_password_in_production

# --- Spring Boot Backend Configuration (TiDB Cloud Serverless MySQL - 25 GiB Free Tier) ---
SPRING_PROFILES_ACTIVE=default
# Note: Using Public Endpoint (`gateway01.us-east-1.prod.aws.tidbcloud.com`) so it connects for FREE ($0/mo) from anywhere.
SPRING_DATASOURCE_URL=jdbc:mysql://gateway01.us-east-1.prod.aws.tidbcloud.com:4000/test?sslMode=VERIFY_IDENTITY&tlsVersions=TLSv1.2,TLSv1.3&useServerPrepStmts=true&cachePrepStmts=true&prepStmtCacheSize=250&prepStmtCacheSqlLimit=2048&rewriteBatchedStatements=true&useConfigs=maxPerformance
SPRING_DATASOURCE_USERNAME=your_tidb_username.root
SPRING_DATASOURCE_PASSWORD=your_tidb_secret_password
SHOW_SQL=false
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect
BACKEND_PORT=8080
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0

# --- JWT Authentication ---
JWT_SECRET=replace_with_a_long_super_secure_random_jwt_secret_key_256_bit
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- Next.js Frontend Configuration ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=development

# --- Initial Data Seeder Configuration ---
SEED_ADMIN_EMAIL=admin@hrms.com
SEED_ADMIN_PASSWORD=change_me_in_production
SEED_HR_EMAIL=hr@hrms.com
SEED_HR_PASSWORD=change_me_in_production
SEED_EMPLOYEE_EMAIL=emp@hrms.com
SEED_EMPLOYEE_PASSWORD=change_me_in_production
